{
  "name": "mexc-pro-v2-desktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron:tsc\" \"npm:dev:electron\"",
    "dev:renderer": "vite --port 5173 --strictPort",
    "dev:electron:tsc": "tsc -p electron/tsconfig.json --watch",
    "dev:electron": "wait-on tcp:5173 dist-electron/main.js && electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:bot": "tsc -p tsconfig.bot.json",
    "start:bot": "node dist-bot/bot.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:production": "npx tsx test-production-ready.ts",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.mexcprov2.desktop",
    "productName": "MEXC Pro V2",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "axios": "^1.15.0",
    "clsx": "2.1.1",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^1.8.0",
    "node-telegram-bot-api": "^0.67.0",
    "pino": "^9.6.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hot-toast": "^2.6.0",
    "sql.js": "^1.12.0",
    "tailwind-merge": "3.4.0",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.2",
    "@types/node": "22.19.17",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "@vitest/ui": "^2.1.9",
    "concurrently": "^9.2.1",
    "electron": "^37.2.1",
    "electron-builder": "^26.0.12",
    "tailwindcss": "4.1.17",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "vite": "7.2.4",
    "vite-plugin-singlefile": "2.3.0",
    "vitest": "^2.1.9",
    "wait-on": "^8.0.5"
  }
}
