{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "outDir": "dist-bot",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": false,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "types": ["node"]
  },
  "include": [
    "bot.ts",
    "src/services/**/*.ts",
    "src/utils/**/*.ts",
    "src/types/**/*.ts",
    "src/database/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-bot",
    "dist-electron",
    "src/services/__tests__/**",
    "src/services/autoTradeDaemon.ts",
    "src/store/**",
    "src/workers/**",
    "test-mexc-live.ts",
    "test-production-ready.ts"
  ]
}
